# Nexus Factory Hostinger VPS example environment.
# Copy to .env.hostinger on the VPS and fill real values there.
# Do not commit .env.hostinger or real secrets.

NEXUS_WEB_PORT=3000

POSTGRES_DB=nexus_factory
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-me-on-vps

LIVE_MODE=false
DRY_RUN_DEFAULT=true
APPROVAL_SYSTEM_ENABLED=true
AUTONOMY_LEVEL=supervised

MODEL_SUPERVISOR=gpt-5.5
MODEL_SPECIALIST_DEFAULT=gpt-5.4-mini

# Enable Hermes only after HERMES_API_KEY and NEXUS_MCP_TOKEN are configured.
HERMES_ENABLED=false
HERMES_API_URL=http://hermes-ultron:8642/v1
HERMES_API_KEY=
NEXUS_MCP_TOKEN=
HERMES_PUBLIC_DASHBOARD=false
HERMES_PUBLIC_URL=
HERMES_PUBLIC_EXPOSURE_ACK=false

# Do not provide Etsy, Printify, payment, email, production database,
# or deployment credentials to Hermes.
